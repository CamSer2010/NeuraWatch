# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node / Vite
node_modules/
dist/
.vite/
*.tsbuildinfo

# Model weights
*.pt
*.onnx

# Storage / runtime
backend/storage/frames/*
!backend/storage/frames/.gitkeep
*.sqlite
*.sqlite-journal
*.db
# SQLite WAL-mode sidecar files (NW-1401 opens the DB with
# journal_mode=WAL; these land next to the .db and shouldn't be
# tracked either).
*.db-wal
*.db-shm
*.sqlite-wal
*.sqlite-shm

# Uploaded videos
backend/storage/uploads/*
!backend/storage/uploads/.gitkeep

# Env
.env
.env.local
.env.*.local

# Claude Code (local-only — auto-mutated by the CLI per user)
.claude/settings.local.json

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
