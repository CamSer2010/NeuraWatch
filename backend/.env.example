# Copy to backend/.env and fill in values.
# NW-1002 will read these via Pydantic Settings.

# Inference resolution locked by NW-1004 benchmark on 2026-04-21
# (Apple M4 Max, CPU: 58 FPS at 640, 5x headroom vs the 12 FPS gate).
# Raw numbers: backend/scripts/benchmark_results.json
INFERENCE_IMGSZ=640

# Detection confidence cutoff (TDD default).
CONFIDENCE_THRESHOLD=0.4

# Frames of consecutive state required before a zone transition fires.
DEBOUNCE_FRAMES=2

# Upload size ceiling (MB).
MAX_UPLOAD_SIZE_MB=100

# Storage paths. Defaults are absolute paths anchored at backend/ and
# are resolved by app/config.py. Uncomment + override only to relocate;
# relative overrides are resolved against backend/.
#FRAMES_DIR=storage/frames
#UPLOADS_DIR=storage/uploads
#DATABASE_URL=sqlite:////absolute/path/to/neurawatch.db
